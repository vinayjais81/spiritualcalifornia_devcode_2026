generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SEEKER
  GUIDE
  ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum OnboardingPath {
  SELF_REGISTRATION
  PROACTIVE_INVITE
}

enum ServiceType {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum EventType {
  VIRTUAL
  IN_PERSON
  SOUL_TRAVEL
  RETREAT
}

enum TourTrack {
  ADVENTURE
  HEALING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ProductType {
  DIGITAL
  PHYSICAL
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_RECEIVED
  PAYOUT_PROCESSED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  REVIEW_RECEIVED
  TESTIMONIAL_RECEIVED
  TICKET_PURCHASED
  ORDER_PLACED
  NEW_MESSAGE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum CartItemType {
  PRODUCT
  EVENT_TICKET
  SOUL_TOUR
  SERVICE_BOOKING
}

enum PaymentType {
  FULL
  DEPOSIT
  BALANCE
}

enum TourBookingStatus {
  PENDING
  DEPOSIT_PAID
  FULLY_PAID
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DepartureStatus {
  SCHEDULED
  FULL
  CANCELLED
  COMPLETED
}

enum PromoCodeType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?
  firstName           String
  lastName            String
  avatarUrl           String?
  phone               String?
  isEmailVerified     Boolean   @default(false)
  isActive            Boolean   @default(true)
  isBanned            Boolean   @default(false)
  bannedReason        String?
  googleId            String?   @unique
  emailVerifyToken    String?
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  lastLoginAt         DateTime?
  marketingEmails     Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  roles               UserRole[]
  seekerProfile       SeekerProfile?
  guideProfile        GuideProfile?
  refreshTokens       RefreshToken[]
  reviewsGiven        Review[]       @relation("ReviewAuthor")
  reviewsReceived     Review[]       @relation("ReviewTarget")
  testimonialsGiven   Testimonial[]  @relation("TestimonialAuthor")
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// SEEKER PROFILE
// ─────────────────────────────────────────────

model SeekerProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  bio                 String?
  location            String?
  timezone            String?
  interests           String[]
  onboardingStep      Int      @default(1)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  ticketPurchases TicketPurchase[]
  orders          Order[]
  tourBookings    TourBooking[]
  favorites       Favorite[]

  @@map("seeker_profiles")
}

// ─────────────────────────────────────────────
// GUIDE PROFILE
// ─────────────────────────────────────────────

model GuideProfile {
  id                   String             @id @default(cuid())
  userId               String             @unique
  slug                 String             @unique
  displayName          String
  tagline              String?
  bio                  String?
  location             String?
  studioName           String?
  streetAddress        String?
  city                 String?
  state                String?
  zipCode              String?
  country              String?          @default("United States")
  timezone             String?
  websiteUrl           String?
  instagramUrl         String?
  youtubeUrl           String?
  languages            String[]           @default([])
  modalities           String[]           @default([])
  issuesHelped         String[]           @default([])
  yearsExperience      Int?
  calendarType              String?
  calendarLink              String?
  sessionPricingJson        String?
  calendlyConnected         Boolean  @default(false)
  calendlyAccessToken       String?
  calendlyRefreshToken      String?
  calendlyUserUri           String?
  isPublished          Boolean            @default(false)
  isVerified           Boolean            @default(false)
  verificationStatus   VerificationStatus @default(PENDING)
  onboardingPath       OnboardingPath     @default(SELF_REGISTRATION)
  stripeAccountId      String?
  stripeOnboardingDone Boolean            @default(false)
  algoliaObjectId      String?
  averageRating        Float              @default(0)
  totalReviews         Int                @default(0)
  isFeatured           Boolean            @default(false)
  claimToken           String?            @unique
  claimTokenExpiry     DateTime?
  scrapedSourceUrl     String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      GuideCategory[]
  services        Service[]
  credentials     Credential[]
  media           GuideMedia[]
  blogPosts       BlogPost[]
  events          Event[]
  products        Product[]
  soulTours       SoulTour[]
  availability    Availability[]
  payoutAccount   PayoutAccount?
  payoutRequests  PayoutRequest[]
  subscription    GuideSubscription?

  @@index([slug])
  @@index([isPublished, isVerified])
  @@map("guide_profiles")
}

model GuideMedia {
  id           String       @id @default(cuid())
  guideId      String
  type         String       // 'image' | 'video_url' | 'video_s3'
  url          String
  thumbnailUrl String?
  caption      String?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())

  guide        GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("guide_media")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  iconUrl       String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  subcategories Subcategory[]
  guides        GuideCategory[]

  @@map("categories")
}

model Subcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String
  isApproved Boolean         @default(false)
  isCustom   Boolean         @default(false)
  createdAt  DateTime        @default(now())

  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  guides     GuideCategory[]

  @@unique([categoryId, slug])
  @@map("subcategories")
}

model GuideCategory {
  id            String       @id @default(cuid())
  guideId       String
  categoryId    String
  subcategoryId String?

  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@unique([guideId, categoryId, subcategoryId])
  @@map("guide_categories")
}

// ─────────────────────────────────────────────
// CREDENTIALS & VERIFICATION
// ─────────────────────────────────────────────

model Credential {
  id                 String             @id @default(cuid())
  guideId            String
  title              String
  institution        String?
  issuedYear         Int?
  documentUrl        String?
  verificationStatus VerificationStatus @default(PENDING)
  confidenceScore    Float?
  extractedData      Json?
  adminNotes         String?
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  guide              GuideProfile             @relation(fields: [guideId], references: [id], onDelete: Cascade)
  verificationLog    CredentialVerification[]

  @@map("credentials")
}

model CredentialVerification {
  id           String     @id @default(cuid())
  credentialId String
  stage        String     // 'textract' | 'claude_nlp' | 'admin_review'
  status       String
  result       Json?
  processedAt  DateTime   @default(now())

  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@map("credential_verifications")
}

model PersonaVerification {
  id          String    @id @default(cuid())
  userId      String    @unique
  inquiryId   String    @unique
  status      String
  referenceId String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("persona_verifications")
}

model InstitutionReference {
  id        String   @id @default(cuid())
  name      String
  aliases   String[]
  country   String?
  type      String?  // 'university' | 'certification_body' | 'wellness_school'
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("institution_references")
}

// ─────────────────────────────────────────────
// SERVICES & AVAILABILITY
// ─────────────────────────────────────────────

model Service {
  id          String      @id @default(cuid())
  guideId     String
  name        String
  description String?
  type        ServiceType @default(IN_PERSON)
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("USD")
  durationMin Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  guide       GuideProfile  @relation(fields: [guideId], references: [id], onDelete: Cascade)
  slots       ServiceSlot[]
  bookings    Booking[]

  @@map("services")
}

model Availability {
  id          String       @id @default(cuid())
  guideId     String
  dayOfWeek   Int          // 0=Sun … 6=Sat
  startTime   String       // "09:00"
  endTime     String       // "17:00"
  isRecurring Boolean      @default(true)
  bufferMin   Int          @default(0)
  createdAt   DateTime     @default(now())

  guide       GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("availability")
}

model ServiceSlot {
  id        String   @id @default(cuid())
  serviceId String
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  booking   Booking?

  @@index([serviceId, startTime])
  @@map("service_slots")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id                 String        @id @default(cuid())
  seekerId           String
  serviceId          String
  slotId             String        @unique
  status             BookingStatus @default(PENDING)
  totalAmount        Decimal       @db.Decimal(10, 2)
  currency           String        @default("USD")
  notes              String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  completedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  seeker    SeekerProfile @relation(fields: [seekerId], references: [id])
  service   Service       @relation(fields: [serviceId], references: [id])
  slot      ServiceSlot   @relation(fields: [slotId], references: [id])
  payment   Payment?
  review    Review?

  @@index([seekerId])
  @@index([serviceId])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String?       @unique
  orderId               String?       @unique
  ticketPurchaseId      String?       @unique
  tourBookingId         String?
  stripePaymentIntentId String        @unique
  stripeCheckoutSessionId String?
  stripeTransferId      String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD")
  platformFee           Decimal       @db.Decimal(10, 2)
  guideAmount           Decimal       @db.Decimal(10, 2)
  paymentType           PaymentType   @default(FULL)
  status                PaymentStatus @default(PENDING)
  refundedAmount        Decimal?      @db.Decimal(10, 2)
  stripeRefundId        String?
  paymentMethod         String?       // "card", "apple_pay", "google_pay", "bank_transfer"
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  booking        Booking?        @relation(fields: [bookingId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])
  ticketPurchase TicketPurchase? @relation(fields: [ticketPurchaseId], references: [id])
  tourBooking    TourBooking?    @relation("TourBookingPayments", fields: [tourBookingId], references: [id])

  @@index([status, createdAt])
  @@map("payments")
}

model PayoutAccount {
  id               String   @id @default(cuid())
  guideId          String   @unique
  stripeAccountId  String   @unique
  availableBalance Decimal  @default(0) @db.Decimal(10, 2)
  pendingBalance   Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned      Decimal  @default(0) @db.Decimal(10, 2)
  totalPaidOut     Decimal  @default(0) @db.Decimal(10, 2)
  currency         String   @default("USD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  guide          GuideProfile    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  payoutRequests PayoutRequest[]

  @@map("payout_accounts")
}

model PayoutRequest {
  id              String       @id @default(cuid())
  guideId         String
  payoutAccountId String
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("USD")
  status          PayoutStatus @default(PENDING)
  stripePayoutId  String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())

  guide         GuideProfile  @relation(fields: [guideId], references: [id])
  payoutAccount PayoutAccount @relation(fields: [payoutAccountId], references: [id])

  @@map("payout_requests")
}

// ─────────────────────────────────────────────
// EVENTS & TICKETS
// ─────────────────────────────────────────────

model Event {
  id              String    @id @default(cuid())
  guideId         String
  title           String
  description     String?
  type            EventType
  startTime       DateTime
  endTime         DateTime
  timezone        String    @default("America/Los_Angeles")
  location        String?
  onlineUrl       String?
  zoomMeetingId   String?
  zoomJoinUrl     String?
  coverImageUrl   String?
  isPublished     Boolean   @default(false)
  isCancelled     Boolean   @default(false)
  algoliaObjectId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  guide       GuideProfile      @relation(fields: [guideId], references: [id], onDelete: Cascade)
  ticketTiers EventTicketTier[]

  @@index([guideId, startTime])
  @@map("events")
}

model EventTicketTier {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  capacity    Int
  sold        Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  purchases TicketPurchase[]

  @@map("event_ticket_tiers")
}

model TicketPurchase {
  id               String   @id @default(cuid())
  purchaseGroupId  String   // Groups all tickets from one checkout session
  seekerId         String
  tierId           String
  quantity         Int      @default(1)
  totalAmount      Decimal  @db.Decimal(10, 2)
  bookingFee       Decimal  @default(0) @db.Decimal(10, 2)
  status           TicketStatus @default(PENDING)
  qrCode           String?
  checkedInAt      DateTime?         // Set when QR is scanned at the door
  checkedInBy      String?           // userId of the guide/admin who checked in
  createdAt        DateTime @default(now())

  // Per-attendee details (one TicketPurchase per attendee)
  attendeeName          String?
  attendeeEmail         String?
  dietaryNeeds          String?
  accessibilityNeeds    String?

  seeker  SeekerProfile   @relation(fields: [seekerId], references: [id])
  tier    EventTicketTier @relation(fields: [tierId], references: [id])
  payment Payment?

  @@index([purchaseGroupId])
  @@index([seekerId])
  @@map("ticket_purchases")
}

enum TicketStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

// ─────────────────────────────────────────────
// PRODUCTS & ORDERS
// ─────────────────────────────────────────────

model Product {
  id              String      @id @default(cuid())
  guideId         String
  name            String
  description     String?
  type            ProductType
  price           Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  stockQuantity   Int?
  imageUrls       String[]
  fileS3Key       String?
  digitalFiles    Json?           // Array of { name, size, url } for digital downloads
  shippingInfo    Json?
  isActive        Boolean     @default(true)
  algoliaObjectId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  guide      GuideProfile     @relation(fields: [guideId], references: [id], onDelete: Cascade)
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@index([guideId])
  @@index([type, isActive])
  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  seekerId        String
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal     @db.Decimal(10, 2) @default(0)
  shippingCost    Decimal     @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal     @db.Decimal(10, 2) @default(0)
  taxRate         Decimal?    @db.Decimal(6, 4)   // Snapshot of rate at time of order
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  shippingAddress Json?
  contactEmail    String?
  contactFirstName String?
  contactLastName  String?
  contactPhone    String?
  promoCodeId     String?
  shippingMethodId String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  seeker         SeekerProfile   @relation(fields: [seekerId], references: [id])
  promoCode      PromoCode?      @relation("OrderPromoCode", fields: [promoCodeId], references: [id])
  shippingMethod ShippingMethod? @relation("OrderShippingMethod", fields: [shippingMethodId], references: [id])
  items          OrderItem[]
  payment        Payment?

  @@index([seekerId])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  variantId     String?  // Which ProductVariant was selected (if applicable)
  quantity      Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10, 2)
  downloadUrl   String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model BlogPost {
  id              String       @id @default(cuid())
  guideId         String
  title           String
  slug            String
  content         String
  excerpt         String?
  coverImageUrl   String?
  tags            String[]
  isPublished     Boolean      @default(false)
  publishedAt     DateTime?
  algoliaObjectId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  guide GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, slug])
  @@index([isPublished, publishedAt])
  @@map("blog_posts")
}

// ─────────────────────────────────────────────
// REVIEWS & TESTIMONIALS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  bookingId  String   @unique
  rating     Int
  title      String?
  body       String?
  isApproved Boolean  @default(true)
  isFlagged  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  target  User    @relation("ReviewTarget", fields: [targetId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([targetId, isApproved])
  @@map("reviews")
}

model Testimonial {
  id            String   @id @default(cuid())
  authorId      String
  targetGuideId String
  body          String
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())

  author User @relation("TestimonialAuthor", fields: [authorId], references: [id])

  @@map("testimonials")
}

// ─────────────────────────────────────────────
// FAVORITES
// ─────────────────────────────────────────────

model Favorite {
  id        String        @id @default(cuid())
  seekerId  String
  guideId   String
  createdAt DateTime      @default(now())

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@unique([seekerId, guideId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// PLATFORM SETTINGS & ADMIN
// ─────────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS (Future Phase — Schema Ready)
// ─────────────────────────────────────────────

model GuideSubscription {
  id                   String             @id @default(cuid())
  guideId              String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  guide GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("guide_subscriptions")
}

// ─────────────────────────────────────────────
// SCRAPER (Path A — Proactive Onboarding)
// ─────────────────────────────────────────────

model ScraperJob {
  id             String    @id @default(cuid())
  source         String
  targetUrl      String
  status         String    @default("pending")
  scrapedData    Json?
  guideProfileId String?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
  @@map("scraper_jobs")
}

// ─────────────────────────────────────────────
// CONTACT LEADS
// ─────────────────────────────────────────────

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String   @default("general")
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@map("contact_leads")
}

// ─────────────────────────────────────────────
// CART (Hybrid: client-side for guests, DB-synced on login)
// ─────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String?  @unique
  sessionId String?  @unique // For guest carts before login
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String       @id @default(cuid())
  cartId    String
  itemType  CartItemType
  itemId    String       // Polymorphic: productId, tierId, tourId, serviceId
  variantId String?      // For ProductVariant selection
  quantity  Int          @default(1)
  metadata  Json?        // Extra data (e.g., selected date for service, room type for tour)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, itemType, itemId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// SOUL TOURS (Multi-day retreats & journeys)
// ─────────────────────────────────────────────

model SoulTour {
  id            String   @id @default(cuid())
  guideId       String
  title         String
  slug          String   @unique
  description   String?
  shortDesc     String?
  // startDate/endDate kept for back-compat with existing data + as the
  // tour's "primary" departure summary; bookings always reference TourDeparture.
  startDate     DateTime
  endDate       DateTime
  timezone      String   @default("America/Los_Angeles")
  location      String?
  address       String?
  city          String?
  state         String?
  country       String?  @default("United States")
  basePrice     Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  capacity      Int
  spotsRemaining Int
  coverImageUrl String?
  imageUrls     String[]
  highlights    String[] // Key selling points
  included      String[] // What's included in the price
  notIncluded   String[] // What's NOT included
  requirements  String?  // Participation requirements
  depositMin    Decimal? @db.Decimal(10, 2) // Legacy: total min deposit (kept for back-compat)
  // ── Phase A additions ──
  difficultyLevel       String?   // EASY | MODERATE | CHALLENGING
  languages             String[]  // ["English", "Spanish"]
  meetingPoint          String?   // "Kathmandu Tribhuvan International Airport (KTM)"
  cancellationPolicy    Json?     // { fullRefundDaysBefore: 90, halfRefundDaysBefore: 60 } — falls back to platform default
  balanceDueDaysBefore  Int       @default(60)
  minDepositPerPerson   Decimal?  @db.Decimal(10, 2)
  // ── Listing-page additions (2026-04-17) ──
  trackType             TourTrack?   // ADVENTURE | HEALING — drives public listing tabs
  latestUpdate          String?      // Guide's latest announcement shown on tour card
  latestUpdateAt        DateTime?
  // ─────────────────────
  isPublished   Boolean  @default(false)
  isCancelled   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guide      GuideProfile       @relation(fields: [guideId], references: [id], onDelete: Cascade)
  roomTypes  TourRoomType[]
  bookings   TourBooking[]
  departures TourDeparture[]
  itinerary  TourItineraryDay[]

  @@index([guideId, startDate])
  @@index([slug])
  @@index([isPublished, startDate])
  @@map("soul_tours")
}

// ─────────────────────────────────────────────
// TOUR DEPARTURES — bookable instances of a tour template
// ─────────────────────────────────────────────

model TourDeparture {
  id              String          @id @default(cuid())
  tourId          String
  startDate       DateTime
  endDate         DateTime
  capacity        Int
  spotsRemaining  Int
  status          DepartureStatus @default(SCHEDULED)
  priceOverride   Decimal?        @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tour     SoulTour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings TourBooking[]

  @@index([tourId, startDate])
  @@index([status, startDate])
  @@map("tour_departures")
}

// ─────────────────────────────────────────────
// TOUR ITINERARY — day-by-day schedule
// ─────────────────────────────────────────────

model TourItineraryDay {
  id            String   @id @default(cuid())
  tourId        String
  dayNumber     Int
  title         String
  description   String
  location      String?
  meals         String[] // ["breakfast", "lunch", "dinner"]
  accommodation String?
  activities    String[]
  imageUrl      String?
  createdAt     DateTime @default(now())

  tour SoulTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber])
  @@map("tour_itinerary_days")
}

model TourRoomType {
  id            String  @id @default(cuid())
  tourId        String
  name          String  // "Standard", "Deluxe", "Premium"
  description   String?
  pricePerNight Decimal @db.Decimal(10, 2)
  totalPrice    Decimal @db.Decimal(10, 2) // Pre-calculated for full stay
  capacity      Int
  available     Int
  amenities     String[]
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())

  tour     SoulTour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings TourBooking[]

  @@map("tour_room_types")
}

model TourBooking {
  id               String            @id @default(cuid())
  tourId           String
  departureId      String?           // Phase A: bookings now reference a specific departure
  seekerId         String
  roomTypeId       String
  travelers        Int               @default(1)
  totalAmount      Decimal           @db.Decimal(10, 2)
  depositAmount    Decimal?          @db.Decimal(10, 2)
  chosenDepositAmount Decimal?       @db.Decimal(10, 2) // What the user actually picked in checkout
  depositPaidAt    DateTime?
  balanceAmount    Decimal?          @db.Decimal(10, 2)
  balanceDueAt     DateTime?
  balanceReminderSentAt DateTime?
  balancePaidAt    DateTime?
  holdExpiresAt    DateTime?         // 24h hold; cleared on DEPOSIT_PAID
  bookingReference String?           @unique // Short human code e.g. "SCT-NEPAL-A1B2"
  paymentMethod    String?           // STRIPE_CARD (Phase 2: BANK_TRANSFER, CRYPTO)
  currency         String            @default("USD")
  status           TourBookingStatus @default(PENDING)
  // Booking-level health & preference fields (per design Step 3)
  dietaryRequirements String?        // e.g. "vegetarian"
  dietaryNotes        String?
  healthConditions    String?
  intentions          String?
  // Legacy free-text catch-all
  specialRequests  String?
  // Primary contact (kept for back-compat; now mirrors first traveler in TourBookingTraveler)
  contactFirstName String
  contactLastName  String
  contactEmail     String
  contactPhone     String?
  cancelledAt      DateTime?
  cancellationReason String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tour      SoulTour              @relation(fields: [tourId], references: [id])
  departure TourDeparture?        @relation(fields: [departureId], references: [id])
  seeker    SeekerProfile         @relation(fields: [seekerId], references: [id])
  roomType  TourRoomType          @relation(fields: [roomTypeId], references: [id])
  payments  Payment[]             @relation("TourBookingPayments")
  travelers_rel TourBookingTraveler[]

  @@index([tourId])
  @@index([departureId])
  @@index([seekerId])
  @@index([status, holdExpiresAt])
  @@index([status, balanceDueAt])
  @@map("tour_bookings")
}

// ─────────────────────────────────────────────
// TOUR BOOKING TRAVELER — per-person manifest
// passportNumber is AES-256-GCM encrypted at rest (see common/crypto/passport-cipher.ts)
// ─────────────────────────────────────────────

model TourBookingTraveler {
  id              String   @id @default(cuid())
  bookingId       String
  isPrimary       Boolean  @default(false)
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  nationality     String
  passportNumber  String?  // AES-256-GCM encrypted (optional)
  passportExpiry  DateTime?
  email           String?
  phone           String?
  createdAt       DateTime @default(now())

  booking TourBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("tour_booking_travelers")
}

// ─────────────────────────────────────────────
// PRODUCT VARIANTS (Sizes, Colors, SKUs)
// ─────────────────────────────────────────────

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  name          String   // "Size 7", "Blue - Large"
  sku           String?  @unique
  price         Decimal? @db.Decimal(10, 2) // Override product price if set
  stockQuantity Int      @default(0)
  attributes    Json?    // { "size": "7", "color": "Silver" }
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

// ─────────────────────────────────────────────
// PROMO CODES (Discount Engine)
// ─────────────────────────────────────────────

model PromoCode {
  id              String        @id @default(cuid())
  code            String        @unique
  type            PromoCodeType
  amount          Decimal       @db.Decimal(10, 2) // Percentage (0-100) or fixed dollar amount
  minOrderAmount  Decimal?      @db.Decimal(10, 2)
  maxDiscountAmount Decimal?    @db.Decimal(10, 2) // Cap for percentage discounts
  maxUses         Int?          // null = unlimited
  usedCount       Int           @default(0)
  appliesToType   String?       // null = all, "DIGITAL", "PHYSICAL", "EVENT", "TOUR"
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orders Order[] @relation("OrderPromoCode")

  @@index([code])
  @@index([isActive, expiresAt])
  @@map("promo_codes")
}

// ─────────────────────────────────────────────
// SHIPPING & TAX
// ─────────────────────────────────────────────

model ShippingMethod {
  id              String   @id @default(cuid())
  name            String   // "Standard", "Express", "International Priority"
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  estimatedDaysMin Int     // 7
  estimatedDaysMax Int     // 14
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[] @relation("OrderShippingMethod")

  @@map("shipping_methods")
}

model TaxRate {
  id        String   @id @default(cuid())
  state     String   // "CA", "NY"
  country   String   @default("US")
  rate      Decimal  @db.Decimal(6, 4) // 0.0863 = 8.63%
  name      String   // "California State Tax"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([state, country])
  @@map("tax_rates")
}
