# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/spiritual_california

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-characters-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-here
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=spiritual-california-dev
AWS_CLOUDFRONT_URL=

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# v1 commission (legacy, kept for fallback). v2 reads from commission_rates
# table (per-category, with optional per-guide override).
STRIPE_PLATFORM_COMMISSION_PERCENT=15

# v2 Stripe processing fee passthrough — locked decision: passed through to guide.
# US card defaults: 2.9% + $0.30. Provisional values written at charge time;
# reconciliation cron writes ADJUSTMENT entries against actual fees.
STRIPE_PROCESSING_FEE_PERCENT=2.9
STRIPE_PROCESSING_FEE_FLAT=0.30

# v2 minimum payout (locked decision: $50). v1 default was $10.
MIN_PAYOUT_USD=50

# v2 cutover flag. false = v1 directly mutates PayoutAccount columns AND the
#                          ledger writes shadow entries (audit only).
#                  true  = v2 ledger is canonical; payments go through ledger,
#                          balance reads come from ledger SUM via recomputeCachedBalance.
# Flip after running:  npm run backfill:ledger:verify  →  no drift
#                      npm run backfill:ledger:write
# See docs/guide-payouts-v2.md §10 (cutover strategy).
LEDGER_V2_ENABLED=false

# v2 reconciliation alert recipient (TODO P7 final wire).
SUPPORT_EMAIL=support@spiritualcalifornia.com

# Disable scheduled payout jobs (clearance / reconciliation / integrity)
# in tests or CI. Production: leave unset.
# PAYOUTS_TASKS_ENABLED=true

# ─────────────────────────────────────────────
# PII Encryption (Soul Tour passport storage)
# ─────────────────────────────────────────────
# 64-char hex string (32 bytes / 256 bits). Generate with:
#   openssl rand -hex 32
# In production, store in AWS Secrets Manager — never commit a real key.
PASSPORT_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

# ─────────────────────────────────────────────
# Resend (Email)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@spiritualcalifornia.com

# ─────────────────────────────────────────────
# Persona (Identity Verification)
# ─────────────────────────────────────────────
PERSONA_API_KEY=persona_...
PERSONA_WEBHOOK_SECRET=persona_webhook_...
PERSONA_TEMPLATE_ID=itmpl_...

# ─────────────────────────────────────────────
# Algolia (Search)
# ─────────────────────────────────────────────
ALGOLIA_APP_ID=your-app-id
ALGOLIA_ADMIN_API_KEY=your-admin-key
ALGOLIA_SEARCH_API_KEY=your-search-key
ALGOLIA_GUIDES_INDEX=guides
ALGOLIA_EVENTS_INDEX=events
ALGOLIA_PRODUCTS_INDEX=products

# ─────────────────────────────────────────────
# Anthropic (Claude AI)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# Zoom
# ─────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your-account-id
ZOOM_CLIENT_ID=your-client-id
ZOOM_CLIENT_SECRET=your-client-secret

# ─────────────────────────────────────────────
# Google OAuth (optional)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback















