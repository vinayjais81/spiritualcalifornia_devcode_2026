# ─────────────────────────────────────────────
# CMS revalidation (optional)
# ─────────────────────────────────────────────
# Shared secret for the Next.js /api/revalidate-static-page webhook. Must
# match STATIC_PAGE_REVALIDATE_SECRET in the frontend .env. If unset, admin
# CMS edits still save but public pages stay cached for up to 5 minutes.
STATIC_PAGE_REVALIDATE_SECRET=change-me-to-a-shared-secret
