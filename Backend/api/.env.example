# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/spiritual_california

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-characters-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-here
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=spiritual-california-dev
AWS_CLOUDFRONT_URL=

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# v1 commission (legacy, kept for fallback). v2 reads from commission_rates
# table (per-category, with optional per-guide override).
STRIPE_PLATFORM_COMMISSION_PERCENT=15

# v2 Stripe processing fee passthrough — locked decision: passed through to guide.
# US card defaults: 2.9% + $0.30. Provisional values written at charge time;
# reconciliation cron writes ADJUSTMENT entries against actual fees.
STRIPE_PROCESSING_FEE_PERCENT=2.9
STRIPE_PROCESSING_FEE_FLAT=0.30

# Minimum payout threshold. v2.1 policy (2026-06-24) raised this to $100
# (was $50). Surfaced to the guide dashboard via the /config endpoint.
MIN_PAYOUT_USD=100

# v2 cutover flag. false = v1 directly mutates PayoutAccount columns AND the
#                          ledger writes shadow entries (audit only).
#                  true  = v2 ledger is canonical; payments go through ledger,
#                          balance reads come from ledger SUM via recomputeCachedBalance.
# Flip after running:  npm run backfill:ledger:verify  →  no drift
#                      npm run backfill:ledger:write
# See docs/guide-payouts-v2.md §10 (cutover strategy).
LEDGER_V2_ENABLED=false

# v2 reconciliation alert recipient (TODO P7 final wire).
SUPPORT_EMAIL=support@spiritualcalifornia.com

# Disable scheduled payout jobs (clearance / reconciliation / integrity /
# auto-payout) in tests or CI. Production: leave unset.
# PAYOUTS_TASKS_ENABLED=true

# v2.1 automatic cycle-based payouts. Off by default — enable per environment
# only after manual-claim parity is verified. Requires LEDGER_V2_ENABLED=true.
# When on, any guide with releasable balance >= MIN_PAYOUT_USD is paid out
# automatically on the AUTO_PAYOUT_CRON cadence; smaller balances roll over.
AUTO_PAYOUT_ENABLED=false
# Cron for the auto-payout sweep (default 11:00 UTC ~ 04:00 PT, after recon).
AUTO_PAYOUT_CRON=0 11 * * *

# ─────────────────────────────────────────────
# PII Encryption (Soul Tour passport storage)
# ─────────────────────────────────────────────
# 64-char hex string (32 bytes / 256 bits). Generate with:
#   openssl rand -hex 32
# In production, store in AWS Secrets Manager — never commit a real key.
PASSPORT_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

# ─────────────────────────────────────────────
# Resend (Email)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@spiritualcalifornia.com

# ─────────────────────────────────────────────
# Stripe Identity (Identity Verification — ID + selfie)
# Uses STRIPE_SECRET_KEY above. Set the webhook secret from the dedicated
# Identity webhook endpoint; until then the service runs in stub mode.
# ─────────────────────────────────────────────
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Algolia (Search)
# ─────────────────────────────────────────────
ALGOLIA_ENABLED=false
ALGOLIA_APP_ID=your-app-id
ALGOLIA_ADMIN_API_KEY=your-admin-key
ALGOLIA_SEARCH_API_KEY=your-search-key
ALGOLIA_GUIDES_INDEX=guides
ALGOLIA_EVENTS_INDEX=events
ALGOLIA_PRODUCTS_INDEX=products

# ─────────────────────────────────────────────
# Anthropic (Claude AI)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# Zoom
# ─────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your-account-id
ZOOM_CLIENT_ID=your-client-id
ZOOM_CLIENT_SECRET=your-client-secret

# ─────────────────────────────────────────────
# Google OAuth (optional)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback















NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/spiritual_california
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_ACCESS_SECRET=spiritual-california-access-secret-2026-dev-key-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=spiritual-california-refresh-secret-2026-dev-key-here
JWT_REFRESH_EXPIRES_IN=7d
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_S3_BUCKET=placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@spiritualcalifornia.com
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_placeholder
ALGOLIA_APP_ID=placeholder
ALGOLIA_ADMIN_API_KEY=placeholder
ALGOLIA_SEARCH_API_KEY=placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
ZOOM_ACCOUNT_ID=placeholder
ZOOM_CLIENT_ID=placeholder
ZOOM_CLIENT_SECRET=placeholder

# ─────────────────────────────────────────────
# CMS revalidation (optional)
# ─────────────────────────────────────────────
# Shared secret for the Next.js /api/revalidate-static-page webhook. Must
# match STATIC_PAGE_REVALIDATE_SECRET in the frontend .env. If unset, admin
# CMS edits still save but public pages stay cached for up to 5 minutes.
STATIC_PAGE_REVALIDATE_SECRET=change-me-to-a-shared-secret

# ─────────────────────────────────────────────
# Pre-launch test-account domain (optional)
# ─────────────────────────────────────────────
# Bare domain used by the admin convert-test-account workflow. Guides
# registered with an email ending in @<this> are auto-flagged
# User.isTestAccount = true so the /admin/guides "Convert" action can
# later swap the throwaway email for the real one. Defaults to
# scprelaunch.test (RFC-reserved .test TLD, never routes real mail).
# See docs/test-account-conversion.md.
# TEST_ACCOUNT_EMAIL_DOMAIN=scprelaunch.test
